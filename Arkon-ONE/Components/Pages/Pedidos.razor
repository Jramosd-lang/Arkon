 @page "/pedidos"

<div style="padding-top: 20px; padding-left: 20px; min-height: 100vh; display: flex; background-color: #f2f4f6; font-family: 'Inter', sans-serif;">

    <div style="flex: 1 1 0%; padding: 32px; overflow-y: auto; margin-right: 450px;">
        <div style="margin-bottom: 32px;">
            <h1 style="font-size: 2.25rem; line-height: 2.5rem; font-weight: 800; color: #004d5e; letter-spacing: -0.025em; margin-bottom: 4px; font-family: 'Manrope', sans-serif;">Create Order</h1>
            <p style="color: #3f484d; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em;">
                Dashboard / Inventory / <span style="color: #004d5e; font-weight: 700;">New Transaction</span>
            </p>
        </div>

        <div style="display: flex; white-space: nowrap; gap: 24px; flex-wrap: wrap;">

            @foreach(var producto in productos){
                <TarjetaProducto Producto_="producto"/>
            }

        </div>
    </div>

    <div style="position: fixed; width: 450px; background-color: #ffffff; border-left: 1px solid rgba(191, 200, 205, 0.2); display: flex; flex-direction: column; box-shadow: -10px 0 15px -3px rgba(0, 0, 0, 0.1); z-index: 2; right: 0; top: 60px; bottom: 0;">
        <div style="padding: 24px; border-bottom: 1px solid #eceef0;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                <h2 style="font-size: 1.25rem; font-weight: 700; color: #004d5e; font-family: 'Manrope', sans-serif;">Order Panel</h2>
                <span style="font-size: 0.75rem; background-color: #b2ebff; color: #001f27; padding: 4px 12px; border-radius: 9999px; font-weight: 700;">INV-2024-082</span>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 10px; font-weight: 700; color: #3f484d; text-transform: uppercase;">Date</label>
                    <input type="date" value="2024-05-20" style="width: 100%; height: 40px; padding: 0 12px; background-color: #f2f4f6; border: none; border-radius: 0.5rem; font-size: 0.875rem;">
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 10px; font-weight: 700; color: #3f484d; text-transform: uppercase;">Time</label>
                    <input type="time" value="14:30" style="width: 100%; height: 40px; padding: 0 12px; background-color: #f2f4f6; border: none; border-radius: 0.5rem; font-size: 0.875rem;">
                </div>
            </div>
        </div>

        <div style="flex: 1 1 0%; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
            <div style="display: flex; align-items: center; gap: 16px;">
                <div style="width: 48px; height: 48px; border-radius: 4px; background-color: #f7f9fb; overflow: hidden; flex-shrink: 0;">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAMfrVJ0adyx1pWhCC4KoxR99-ZyM1FdN5TUf3UxGm1qcl9Id7gnpjs7XVaKMxJz1Ck8CbaYTXAUj54mtn__BX1oHUZpKSjHjXeXubDFai8SS8v-5-nWm3tmfq8uX5jf1uRHshZ9OpPeXmoyI-kg9j8vzHGeoZT9CeHqQ1WKMRDUOuNF6uuNYwbTay_3LKqCWQg2BQ93GwWOu7FK82_bkEl7KT6PFd3qDzFNLHcyKs9vRyz9KAuKSr4qA1tOm0zJlnXqObzPP1dazsJ" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div style="flex: 1 1 0%;">
                    <p style="font-size: 0.875rem; font-weight: 700; color: #191c1e;">Architect Chrono v1</p>
                    <p style="font-size: 0.75rem; color: #3f484d;">1 x $299.00</p>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <button style="width: 32px; height: 32px; border-radius: 9999px; background-color: #eceef0; border: none; display: flex; align-items: center; justify-content: center; color: #13677b; cursor: pointer;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    </button>
                    <span style="font-size: 0.875rem; font-weight: 700; width: 16px; text-align: center;">1</span>
                    <button style="width: 32px; height: 32px; border-radius: 9999px; background-color: #eceef0; border: none; display: flex; align-items: center; justify-content: center; color: #13677b; cursor: pointer;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    </button>
                </div>
            </div>
        </div>

        <div style="padding: 24px; background-color: #f2f4f6; border-top-left-radius: 2rem; border-top-right-radius: 2rem;">
            <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
                <div style="display: flex; justify-content: space-between; font-size: 0.875rem; color: #3f484d;">
                    <span>Subtotal</span>
                    <span style="font-weight: 600;">$670.00</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 0.875rem; color: #3f484d;">
                    <span>Tax (15%)</span>
                    <span style="font-weight: 600;">$100.50</span>
                </div>
                <div style="height: 1px; background-color: rgba(191, 200, 205, 0.2); margin: 8px 0;"></div>
                <div style="display: flex; justify-content: space-between; font-size: 1.5rem; font-weight: 800; color: #004d5e;">
                    <span>Total</span>
                    <span>$770.50</span>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 10px; font-weight: 700; color: #3f484d; text-transform: uppercase;">Payment</label>
                    <select style="width: 100%; height: 40px; padding: 0 12px; background-color: #ffffff; border: none; border-radius: 0.5rem; font-size: 0.875rem;">
                        <option>Cash (Efectivo)</option>
                        <option>Card (Tarjeta)</option>
                        <option>Transfer (Transferencia)</option>
                    </select>
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 10px; font-weight: 700; color: #3f484d; text-transform: uppercase;">Change</label>
                    <input type="number" placeholder="0.00" style="width: 100%; height: 40px; padding: 0 12px; background-color: #ffffff; border: none; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 700;">
                </div>
            </div>

            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px; background-color: #eceef0; padding: 12px; border-radius: 0.5rem;">
                <input type="checkbox" id="wa-send" style="width: 20px; height: 20px; accent-color: #004d5e;">
                <label for="wa-send" style="font-size: 0.875rem; font-weight: 600; color: #3f484d; display: flex; align-items: center; gap: 8px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" /></svg>
                    Send via WhatsApp
                </label>
            </div>

            <button style="width: 100%; padding: 16px 0; background: linear-gradient(to right, #004d5e, #13677b); color: #ffffff; border: none; border-radius: 0.75rem; font-weight: 700; font-size: 1.125rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 12px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1-2-1z" /><path d="M16 8h-9" /><path d="M16 12H7" /><path d="M16 16H7" /></svg>
                PROCESS ORDER
            </button>
        </div>
    </div>
</div>


