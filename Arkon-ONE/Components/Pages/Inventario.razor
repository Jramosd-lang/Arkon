                <button style="width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center; border-radius: 0.25rem; background: #e0e3e5; border: none; cursor: pointer; color: #3f484d; font-size: 0.75rem; font-weight: 700;">3</button>
                <button style="width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center; border-radius: 0.25rem; background: #e0e3e5; border: none; cursor: pointer; color: #3f484d;">
