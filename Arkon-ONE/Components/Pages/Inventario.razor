                    <!-- Fila 2 — Stock bajo -->
                    <tr style="border-top: 1px solid rgba(191,200,205,.15); background: rgba(255,255,255,.4); transition: background .15s;" onmouseover="this.style.background='#fff'" onmouseout="this.style.background='rgba(255,255,255,.4)'">
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="width: 3rem; height: 3rem; border-radius: 0.5rem; background: #e0e3e5; overflow: hidden;">
                                <img alt="Baldosas" style="width: 100%; height: 100%; object-fit: cover;" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC0zWGrEpMQROUdMEqe6CKHRvBJQBhzUygbujajP3LlJT2LDpP1R_N1qtbiDLhLsecCyXFtgDmLFbmXHWzf7aaOogIOfyRaiWVcs1BCLB3Fapf8hCiMzkB1MEeOxgtsIQ5LN0A6E0OPddRk9SD2cp4j_XhvKJmsxjzpllEK0KzWV3XEuEyN1vyNY1n0MWPb-IPEM89LjD2wGrcmRBUHK0V-SzfgKaY03MXueKazW_STDfkSTxluSv7Mtj3eNl3wcL6evSPjwGMTAqeO" />
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="font-weight: 700; color: #191c1e; font-family: 'Manrope', sans-serif;">Baldosa de Porcelana Gris Mate</div>
                            <div style="font-size: 0.625rem; color: #3f484d; font-family: monospace;">SKU: TL-MG-PORC</div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <span style="display: inline-block; padding: 4px 12px; background: #eceef0; font-size: 0.625rem; font-weight: 700; color: #3f484d; border-radius: 0.375rem;">Acabados</span>
                        </td>
                        <td style="padding: 1.25rem 1.5rem; text-align: center;">
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                <span style="font-size: 0.875rem; font-weight: 700; color: #ba1a1a;">12 Paquetes</span>
                                <div style="width: 5rem; height: 6px; background: #eceef0; border-radius: 999px; overflow: hidden;">
                                    <div style="height: 100%; background: #ba1a1a; width: 15%;"></div>
                                </div>
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="font-size: 0.75rem; font-weight: 500; color: #191c1e;">14 Oct, 2023</div>
                            <div style="font-size: 0.625rem; color: #3f484d;">02:15 PM por Sarah L.</div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem; text-align: right;">
                            <button style="padding: 4px 12px; background: #004d5e; color: #fff; font-size: 0.625rem; font-weight: 700; border: none; border-radius: 0.5rem; cursor: pointer; font-family: 'Inter', sans-serif;">PEDIR AHORA</button>
                        </td>
                    </tr>

                    <!-- Fila 3 -->
                    <tr style="border-top: 1px solid rgba(191,200,205,.15); transition: background .15s;" onmouseover="this.style.background='#fff'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="width: 3rem; height: 3rem; border-radius: 0.5rem; background: #e0e3e5; overflow: hidden;">
                                <img alt="Cables" style="width: 100%; height: 100%; object-fit: cover;" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCk-OqQpbep8_ojmR76jIAFO9lo08S4SJhnYb065Eenq55oW3qek6jvahUp35iniZLYy2WhQ8tc_rfQbIhKz2XMd94oIDMIkw6lrXgYTu7C_WAtdc7Gon4hs75w0-az5g3FGFZq8s7gIVjPQ468GukUDHUsONqFz4mIuVDhHr99P-jajbEJqwfFj4Pvy1SI8--K-8azjtPEGzmMA5MALA6R5MOu6xK80nDlfkmlqem6lFfRbQXrmzQGirfxCtS7CBMIc_oOD_jZAWhW" />
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="font-weight: 700; color: #191c1e; font-family: 'Manrope', sans-serif;">Cable de Cobre 2.5mm</div>
                            <div style="font-size: 0.625rem; color: #3f484d; font-family: monospace;">SKU: EL-CC-25MM</div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <span style="display: inline-block; padding: 4px 12px; background: #eceef0; font-size: 0.625rem; font-weight: 700; color: #3f484d; border-radius: 0.375rem;">Eléctrico</span>
                        </td>
                        <td style="padding: 1.25rem 1.5rem; text-align: center;">
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                <span style="font-size: 0.875rem; font-weight: 700; color: #004d5e;">82 Rollos</span>
                                <div style="width: 5rem; height: 6px; background: #eceef0; border-radius: 999px; overflow: hidden;">
                                    <div style="height: 100%; background: #13677b; width: 50%;"></div>
                                </div>
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="font-size: 0.75rem; font-weight: 500; color: #191c1e;">13 Oct, 2023</div>
                            <div style="font-size: 0.625rem; color: #3f484d;">11:00 AM por System Bot</div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem; text-align: right;">
                            <button style="padding: 0.5rem; color: #3f484d; background: none; border: none; cursor: pointer; border-radius: 0.375rem;">
                                <i data-lucide="pencil" style="width: 16px; height: 16px;"></i>
                            </button>
                            <button style="padding: 0.5rem; color: #3f484d; background: none; border: none; cursor: pointer; border-radius: 0.375rem;">
                                <i data-lucide="history" style="width: 16px; height: 16px;"></i>
