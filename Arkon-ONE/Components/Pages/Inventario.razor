</main>

<!-- FAB -->
<button style="position: fixed; bottom: 2rem; right: 2rem; width: 3.5rem; height: 3.5rem; background: #004d5e; color: #fff; border-radius: 50%; border: none; box-shadow: 0 8px 24px rgba(0,77,94,.3); display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 50; transition: transform .2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
    <i data-lucide="message-circle" style="width: 22px; height: 22px;"></i>
</button>
