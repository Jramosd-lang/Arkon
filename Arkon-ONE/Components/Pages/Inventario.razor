                        <td style="padding: 1.25rem 1.5rem; text-align: center;">
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                <span style="font-size: 0.875rem; font-weight: 700; color: #004d5e;">452 Unidades</span>
                                <div style="width: 5rem; height: 6px; background: #eceef0; border-radius: 999px; overflow: hidden;">
                                    <div style="height: 100%; background: #22c55e; width: 75%;"></div>
