@page "/inventario"


<!-- ── Contenido Principal ── -->
<main style="min-height: 100vh; background: #f7f9fb; padding: 2rem; font-family: 'Inter', sans-serif;">

    <!-- Encabezado -->
    <section style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; gap: 1.5rem;">
        <div>
            <nav style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                <span style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; color: #3f484d;">ERP Shell</span>
                <i data-lucide="chevron-right" style="width: 12px; height: 12px; color: #3f484d;"></i>
                <span style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; color: #004d5e;">Gestión de Inventario</span>
            </nav>
            <h1 style="font-size: 2.25rem; font-weight: 800; color: #004d5e; line-height: 1.1; margin: 0 0 0.5rem; font-family: 'Manrope', sans-serif;">Niveles de Stock Actuales</h1>
            <p style="color: #3f484d; margin: 0; max-width: 32rem; font-size: 0.9rem;">Gestiona tus suministros y componentes en todos los almacenes globales desde una única fuente de verdad.</p>
        </div>
        <div style="display: flex; gap: 0.75rem;">
            <button style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background: #e0e3e5; color: #191c1e; font-weight: 600; font-size: 0.875rem; border: none; border-radius: 0.75rem; cursor: pointer; font-family: 'Inter', sans-serif;">
                <i data-lucide="plus" style="width: 18px; height: 18px;"></i>
                Agregar Stock
            </button>
            <button style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; background: linear-gradient(135deg, #004d5e, #13677b); color: #fff; font-weight: 700; font-size: 0.875rem; border: none; border-radius: 0.75rem; box-shadow: 0 8px 16px rgba(0,77,94,.2); cursor: pointer; font-family: 'Inter', sans-serif;">
                <i data-lucide="scan-line" style="width: 18px; height: 18px;"></i>
                Escanear QR
            </button>
        </div>
    </section>

    <!-- Tarjetas de métricas -->
    <section style="display: grid; grid-template-columns: 4fr 5fr 3fr; gap: 1.5rem; margin-bottom: 2.5rem;">

        <!-- Total SKUs -->
        <div style="background: #fff; padding: 1.5rem; border-radius: 1rem; box-shadow: 0 1px 4px rgba(0,0,0,.06);">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                <span style="font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #3f484d;">Total SKUs</span>
                <div style="width: 2.5rem; height: 2.5rem; background: #b2ebff; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; color: #004d5e;">
                    <i data-lucide="tag" style="width: 18px; height: 18px;"></i>
                </div>
            </div>
            <div style="font-size: 1.875rem; font-weight: 700; color: #004d5e; font-family: 'Manrope', sans-serif;">1,248</div>
            <div style="font-size: 0.625rem; color: #16a34a; font-weight: 700; margin-top: 4px; display: flex; align-items: center; gap: 4px;">
                <i data-lucide="trending-up" style="width: 12px; height: 12px;"></i>
                +12 NUEVOS ARTÍCULOS ESTE MES
            </div>
        </div>

        <!-- Salud del Stock -->
        <div style="background: #fff; padding: 1.5rem; border-radius: 1rem; box-shadow: 0 1px 4px rgba(0,0,0,.06);">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                <span style="font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #3f484d;">Salud del Stock</span>
                <div style="width: 2.5rem; height: 2.5rem; background: #ffdad6; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; color: #ba1a1a;">
                    <i data-lucide="triangle-alert" style="width: 18px; height: 18px;"></i>
                </div>
            </div>
            <div style="display: flex; align-items: flex-end; gap: 0.75rem;">
                <div style="font-size: 1.875rem; font-weight: 700; color: #191c1e; font-family: 'Manrope', sans-serif;">94.2%</div>
                <div style="flex: 1; height: 8px; background: #eceef0; border-radius: 999px; overflow: hidden; margin-bottom: 8px;">
                    <div style="height: 100%; background: #004d5e; width: 94.2%;"></div>
                </div>
            </div>
            <div style="font-size: 0.625rem; font-weight: 700; text-transform: uppercase; color: #3f484d; margin-top: 4px;">12 artículos sin stock actualmente</div>
        </div>

        <!-- Almacenamiento -->
        <div style="background: #13677b; padding: 1.5rem; border-radius: 1rem; box-shadow: 0 8px 24px rgba(19,103,123,.25); position: relative; overflow: hidden;">
            <div style="position: relative; z-index: 1;">
                <span style="font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #9ce2fa;">Almacén Usado</span>
                <div style="font-size: 1.875rem; font-weight: 700; color: #fff; margin-top: 1rem; font-family: 'Manrope', sans-serif;">82%</div>
                <p style="font-size: 0.625rem; color: #9ce2fa; margin: 0.5rem 0 0; font-weight: 500;">Almacenes A y C alcanzando capacidad</p>
            </div>
            <div style="position: absolute; bottom: -1rem; right: -1rem; opacity: .1;">
                <i data-lucide="warehouse" style="width: 80px; height: 80px; color: #fff;"></i>
            </div>
        </div>

    </section>

    <!-- Tabla de Inventario -->
    <section style="background: #f2f4f6; border-radius: 1rem; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.06);">

        <!-- Barra de filtros -->
        <div style="padding: 1.5rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
                <button style="padding: 0.5rem 1rem; background: #fff; font-size: 0.75rem; font-weight: 700; color: #004d5e; border-radius: 0.5rem; border: 2px solid rgba(0,77,94,.1); cursor: pointer; font-family: 'Inter', sans-serif;">Todo el Inventario</button>
                <button style="padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 700; color: #3f484d; background: none; border: none; cursor: pointer; font-family: 'Inter', sans-serif;">Stock Bajo</button>
                <button style="padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 700; color: #3f484d; background: none; border: none; cursor: pointer; font-family: 'Inter', sans-serif;">Materias Primas</button>
                <button style="padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 700; color: #3f484d; background: none; border: none; cursor: pointer; font-family: 'Inter', sans-serif;">Productos Terminados</button>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-size: 0.75rem; font-weight: 700; color: #3f484d;">ORDENAR POR</span>
                <select style="background: transparent; border: none; font-size: 0.75rem; font-weight: 700; color: #004d5e; cursor: pointer; outline: none; font-family: 'Inter', sans-serif;">
                    <option>Última Actualización</option>
                    <option>Nivel de Stock (Mayor-Menor)</option>
                    <option>Nombre (A-Z)</option>
                </select>
            </div>
        </div>

        <!-- Tabla -->
        <div style="overflow-x: auto;">
            <table style="width: 100%; text-align: left; border-collapse: collapse;">
                <thead>
                    <tr style="background: rgba(230,232,234,.5);">
                        <th style="padding: 1rem 1.5rem; font-size: 0.625rem; font-weight: 800; color: #3f484d; text-transform: uppercase; letter-spacing: 0.1em;">Imagen</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.625rem; font-weight: 800; color: #3f484d; text-transform: uppercase; letter-spacing: 0.1em;">Nombre</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.625rem; font-weight: 800; color: #3f484d; text-transform: uppercase; letter-spacing: 0.1em;">Categoría</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.625rem; font-weight: 800; color: #3f484d; text-transform: uppercase; letter-spacing: 0.1em; text-align: center;">Nivel de Stock</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.625rem; font-weight: 800; color: #3f484d; text-transform: uppercase; letter-spacing: 0.1em;">Última Actualización</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.625rem; font-weight: 800; color: #3f484d; text-transform: uppercase; letter-spacing: 0.1em; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody>

