        </div>

        <!-- Sucursal -->
        <div style="background: #fff; padding: 1.25rem; border-radius: 0.75rem; box-shadow: 0 1px 4px rgba(0,0,0,.06); display: flex; flex-direction: column; gap: 0.75rem;">
