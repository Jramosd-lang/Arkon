                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-family: monospace; font-size: 0.75rem; font-weight: 700; color: #3f484d;">#ORD-8819</span>
                    </td>
                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-size: 0.875rem; font-weight: 600; color: #191c1e; display: block;">Theodore Miller</span>
                        <span style="font-size: 0.75rem; color: #3f484d;">tm@miller-cons.com</span>
                    </td>
