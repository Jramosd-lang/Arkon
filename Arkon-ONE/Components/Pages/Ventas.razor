                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-size: 0.875rem; font-weight: 600; color: #191c1e; display: block;">Marcus Thorne</span>
                        <span style="font-size: 0.75rem; color: #3f484d;">m.thorne@industrial.co</span>
                    </td>
                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-size: 0.75rem; color: #3f484d;">20 Oct, 2023</span>
                    </td>
                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-size: 0.875rem; font-weight: 700; color: #191c1e;">$2,100.00</span>
                    </td>
                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="padding: 4px 12px; background: #cfe2ff; color: #084298; font-size: 0.625rem; font-weight: 700; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.06em;">Enviada</span>
                    </td>
                    <td style="padding: 1.25rem 1.5rem; text-align: right;">
