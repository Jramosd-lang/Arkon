                <tr style="border-top: 1px solid #eceef0; transition: background .15s;" onmouseover="this.style.background='#f2f4f6'" onmouseout="this.style.background='transparent'">
                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-family: monospace; font-size: 0.75rem; font-weight: 700; color: #3f484d;">#ORD-8790</span>
                    </td>
                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-size: 0.875rem; font-weight: 600; color: #191c1e; display: block;">Sienna Brooks</span>
                        <span style="font-size: 0.75rem; color: #3f484d;">s.brooks@gmail.com</span>
                    </td>
                    <td style="padding: 1.25rem 1.5rem;">
                        <span style="font-size: 0.75rem; color: #3f484d;">21 Oct, 2023</span>
