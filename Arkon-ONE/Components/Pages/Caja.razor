@page "/caja"

<div style="min-height: 100vh; background-color: #f7f9fb; font-family: Inter, sans-serif; color: #191c1e;">
    <div style="padding: 2rem; max-width: 80rem; margin-left: auto; margin-right: auto;">

        <!-- Breadcrumbs & Title -->
        <div style="display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 2rem;">
            <span style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #70787e; font-family: Inter, sans-serif;">
                Financial Management / Cashier
            </span>
            <h1 style="font-size: 2.25rem; font-weight: 800; font-family: Manrope, sans-serif; color: #004d5e;">
                Caja
            </h1>
        </div>

        <!-- Bento Layout for Cashier Info -->
        <div style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.5rem;">

            <!-- Hero Section: Daily Earnings -->
            <div style="grid-column: span 8; background-color: #ffffff; border-radius: 0.75rem; padding: 2.5rem; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden;">

                <!-- Subtle Background Pattern -->
                <div style="position: absolute; top: 0; right: 0; width: 16rem; height: 16rem; background-color: rgba(0, 77, 94, 0.05); border-radius: 50%; margin-right: -5rem; margin-top: -5rem; filter: blur(75px);"></div>

                <div style="position: relative; z-index: 10;">
                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                        <span style="color: #004d5e; background-color: #b2ebff; padding: 0.5rem; border-radius: 0.5rem; display: inline-flex;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="5" width="20" height="14" rx="2" />
                                <line x1="2" y1="10" x2="22" y2="10" />
                            </svg>
                        </span>
                        <h2 style="font-size: 1.25rem; font-weight: 700; font-family: Manrope, sans-serif; color: #191c1e;">
                            Daily Earnings
                        </h2>
                    </div>
                    <div style="display: flex; align-items: baseline; gap: 0.5rem;">
                        <span style="font-size: 3rem; font-weight: 900; font-family: Manrope, sans-serif; color: #004d5e;">
                            $12,450.00
                        </span>
                        <span style="color: #13677b; font-weight: 600;">
                            +14.2% from yesterday
                        </span>
                    </div>
                </div>

                <div style="margin-top: 3rem; display: flex; gap: 1rem; position: relative; z-index: 10;">
                    <div style="flex: 1; background-color: #f2f4f6; border-radius: 0.75rem; padding: 1.5rem;">
                        <p style="font-size: 0.875rem; font-family: Inter, sans-serif; color: #70787e; margin-bottom: 0.25rem;">
                            Cash on Hand
                        </p>
                        <p style="font-size: 1.5rem; font-weight: 700; font-family: Manrope, sans-serif; color: #191c1e;">
                            $4,200.00
                        </p>
                    </div>
                    <div style="flex: 1; background-color: #f2f4f6; border-radius: 0.75rem; padding: 1.5rem;">
                        <p style="font-size: 0.875rem; font-family: Inter, sans-serif; color: #70787e; margin-bottom: 0.25rem;">
                            Card Terminal
                        </p>
                        <p style="font-size: 1.5rem; font-weight: 700; font-family: Manrope, sans-serif; color: #191c1e;">
                            $8,250.00
                        </p>
                    </div>
                </div>
            </div>

            <!-- Action Section: Close Cash -->
            <div style="grid-column: span 4; background-color: #13677b; border-radius: 0.75rem; padding: 2rem; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;">
                <div style="background-color: #004d5e; padding: 1rem; border-radius: 50%; margin-bottom: 1.5rem;">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="white" stroke="none">
                        <rect x="5" y="11" width="14" height="10" rx="2" ry="2" />
                        <path d="M12 17a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                </div>
                <h3 style="font-size: 1.5rem; font-weight: 700; font-family: Manrope, sans-serif; color: #ffffff; margin-bottom: 0.5rem;">
                    Close Cash Session
                </h3>
                <p style="color: #9ce2fa; font-size: 0.875rem; margin-bottom: 2rem; line-height: 1.625; padding-left: 1rem; padding-right: 1rem;">
                    All data will be sent to the database and the owner via WhatsApp
                </p>

                <!-- Password Input Area -->
                <div style="width: 100%;">
                    <div style="position: relative; margin-bottom: 1rem;">
                        <input type="password" placeholder="Admin PIN"
                               style="width: 100%; background-color: #ffffff; color: #191c1e; text-align: center; padding-top: 1rem; padding-bottom: 1rem; border-radius: 0.75rem; border: none; font-weight: 700; font-size: 1.25rem; letter-spacing: 0.5em; outline: none;" />
                    </div>
                    <button style="width: 100%; background: linear-gradient(to bottom right, #004d5e, #13677b); color: #ffffff; font-weight: 700; padding-top: 1rem; padding-bottom: 1rem; border-radius: 0.75rem; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem; transition: transform 0.2s;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                        CLOSE CASH
                    </button>
                </div>
            </div>

            <!-- Transaction Log -->
            <div style="grid-column: span 12; background-color: #f2f4f6; border-radius: 0.75rem; overflow: hidden;">
                <div style="padding: 2rem; padding-bottom: 1rem; display: flex; justify-content: space-between; align-items: center;">
                    <h3 style="font-size: 1.125rem; font-weight: 700; font-family: Manrope, sans-serif; color: #191c1e;">
                        Recent Activity
                    </h3>
                    <button style="color: #004d5e; font-weight: 700; font-family: Inter, sans-serif; display: flex; align-items: center; gap: 0.5rem; background: none; border: none; cursor: pointer;">
                        View All
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12" />
                            <polyline points="12 5 19 12 12 19" />
                        </svg>
                    </button>
                </div>

                <div style="padding-left: 2rem; padding-right: 2rem; padding-bottom: 2rem;">
                    <div style="display: flex; flex-direction: column; gap: 0.75rem;">

                        <!-- Item 1 -->
                        <div style="background-color: #ffffff; padding: 1.25rem; border-radius: 0.75rem; display: flex; align-items: center; justify-content: space-between; cursor: pointer;">
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <div style="height: 3rem; width: 3rem; border-radius: 0.5rem; background-color: #f2f4f6; display: flex; align-items: center; justify-content: center; color: #004d5e;">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                        <line x1="3" y1="6" x2="21" y2="6" />
                                        <path d="M16 10a4 4 0 0 1-8 0" />
                                    </svg>
                                </div>
                                <div>
                                    <h4 style="font-weight: 700; color: #191c1e; font-family: Manrope, sans-serif;">
                                        Order #8429
                                    </h4>
                                    <p style="font-size: 0.875rem; color: #70787e; font-family: Inter, sans-serif;">
                                        14:22 PM • Cash Payment
                                    </p>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <p style="font-size: 1.125rem; font-weight: 700; color: #004d5e;">
                                    +$1,240.00
                                </p>
                                <span style="font-size: 0.6rem; font-weight: 900; text-transform: uppercase; color: #48626f; background-color: #cbe7f6; padding-left: 0.5rem; padding-right: 0.5rem; padding-top: 0.25rem; padding-bottom: 0.25rem; border-radius: 0.125rem;">
                                    Completed
                                </span>
                            </div>
                        </div>

                        <!-- Item 2 -->
                        <div style="background-color: #ffffff; padding: 1.25rem; border-radius: 0.75rem; display: flex; align-items: center; justify-content: space-between; cursor: pointer;">
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <div style="height: 3rem; width: 3rem; border-radius: 0.5rem; background-color: #f2f4f6; display: flex; align-items: center; justify-content: center; color: #004d5e;">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
                                        <line x1="1" y1="10" x2="23" y2="10" />
                                    </svg>
                                </div>
                                <div>
                                    <h4 style="font-weight: 700; color: #191c1e; font-family: Manrope, sans-serif;">
                                        Order #8428
                                    </h4>
                                    <p style="font-size: 0.875rem; color: #70787e; font-family: Inter, sans-serif;">
                                        13:58 PM • Visa **** 4920
                                    </p>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <p style="font-size: 1.125rem; font-weight: 700; color: #004d5e;">
                                    +$450.50
                                </p>
                                <span style="font-size: 0.6rem; font-weight: 900; text-transform: uppercase; color: #48626f; background-color: #cbe7f6; padding-left: 0.5rem; padding-right: 0.5rem; padding-top: 0.25rem; padding-bottom: 0.25rem; border-radius: 0.125rem;">
                                    Completed
                                </span>
                            </div>
                        </div>

                        <!-- Item 3 -->
                        <div style="background-color: #ffffff; padding: 1.25rem; border-radius: 0.75rem; display: flex; align-items: center; justify-content: space-between; cursor: pointer;">
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <div style="height: 3rem; width: 3rem; border-radius: 0.5rem; background-color: rgba(255, 218, 214, 0.3); display: flex; align-items: center; justify-content: center; color: #ba1a1a;">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="9 14 4 9 9 4" />
                                        <path d="M20 20v-7a4 4 0 0 0-4-4H4" />
                                    </svg>
                                </div>
                                <div>
                                    <h4 style="font-weight: 700; color: #191c1e; font-family: Manrope, sans-serif;">
                                        Refund #229
                                    </h4>
                                    <p style="font-size: 0.875rem; color: #70787e; font-family: Inter, sans-serif;">
                                        12:15 PM • Return Merchandise
                                    </p>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <p style="font-size: 1.125rem; font-weight: 700; color: #ba1a1a;">
                                    -$85.00
                                </p>
                                <span style="font-size: 0.6rem; font-weight: 900; text-transform: uppercase; color: #ba1a1a; background-color: #ffdad6; padding-left: 0.5rem; padding-right: 0.5rem; padding-top: 0.25rem; padding-bottom: 0.25rem; border-radius: 0.125rem;">
                                    Voided
                                </span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Floating Security Tag -->
    <div style="position: fixed; bottom: 1.5rem; right: 1.5rem; background-color: rgba(224, 227, 229, 0.6); backdrop-filter: blur(24px); border: 1px solid rgba(191, 200, 205, 0.2); padding-top: 0.5rem; padding-bottom: 0.5rem; padding-left: 1rem; padding-right: 1rem; border-radius: 9999px; display: flex; align-items: center; gap: 0.5rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); z-index: 50;">
        <div style="width: 0.5rem; height: 0.5rem; border-radius: 50%; background-color: #004d5e;"></div>
        <span style="font-size: 0.75rem; font-weight: 700; color: #3f484d; font-family: Inter, sans-serif; letter-spacing: -0.025em;">
            ENCRYPTED ERP CONNECTION ACTIVE
        </span>
    </div>
</div>

